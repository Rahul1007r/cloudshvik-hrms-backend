USE hrms_db;

-- ── Salary Structures ─────────────────────────────────────
CREATE TABLE IF NOT EXISTS salary_structures (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  employee_id     INT NOT NULL UNIQUE,
  effective_from  DATE NOT NULL,
  basic_salary    DECIMAL(12,2) NOT NULL DEFAULT 0,
  hra             DECIMAL(12,2) DEFAULT 0,
  da              DECIMAL(12,2) DEFAULT 0,
  medical_allow   DECIMAL(12,2) DEFAULT 0,
  travel_allow    DECIMAL(12,2) DEFAULT 0,
  special_allow   DECIMAL(12,2) DEFAULT 0,
  other_allow     DECIMAL(12,2) DEFAULT 0,
  -- Deductions
  pf_employee     DECIMAL(12,2) DEFAULT 0,   -- 12% of basic
  pf_employer     DECIMAL(12,2) DEFAULT 0,   -- 12% of basic
  esi_employee    DECIMAL(12,2) DEFAULT 0,   -- 0.75% of gross
  esi_employer    DECIMAL(12,2) DEFAULT 0,   -- 3.25% of gross
  professional_tax DECIMAL(12,2) DEFAULT 0, -- slab-based
  tds             DECIMAL(12,2) DEFAULT 0,
  loan_deduction  DECIMAL(12,2) DEFAULT 0,
  other_deduction DECIMAL(12,2) DEFAULT 0,
  -- CTC
  gross_salary    DECIMAL(12,2) GENERATED ALWAYS AS (
    basic_salary + hra + da + medical_allow + travel_allow + special_allow + other_allow
  ) STORED,
  ctc             DECIMAL(12,2) GENERATED ALWAYS AS (
    basic_salary + hra + da + medical_allow + travel_allow + special_allow + other_allow + pf_employer + esi_employer
  ) STORED,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (employee_id) REFERENCES employees(id) ON DELETE CASCADE
);

-- ── Payroll Runs ──────────────────────────────────────────
CREATE TABLE IF NOT EXISTS payroll_runs (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  month           INT NOT NULL,
  year            INT NOT NULL,
  status          ENUM('Draft','Processing','Completed','Cancelled') DEFAULT 'Draft',
  total_employees INT DEFAULT 0,
  total_gross     DECIMAL(14,2) DEFAULT 0,
  total_deductions DECIMAL(14,2) DEFAULT 0,
  total_net       DECIMAL(14,2) DEFAULT 0,
  processed_by    INT NULL,
  processed_at    DATETIME NULL,
  remarks         TEXT NULL,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  UNIQUE KEY uq_month_year (month, year),
  FOREIGN KEY (processed_by) REFERENCES users(id) ON DELETE SET NULL
);

-- ── Payslips ──────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS payslips (
  id                INT AUTO_INCREMENT PRIMARY KEY,
  payroll_run_id    INT NOT NULL,
  employee_id       INT NOT NULL,
  month             INT NOT NULL,
  year              INT NOT NULL,
  -- Earnings
  basic_salary      DECIMAL(12,2) DEFAULT 0,
  hra               DECIMAL(12,2) DEFAULT 0,
  da                DECIMAL(12,2) DEFAULT 0,
  medical_allow     DECIMAL(12,2) DEFAULT 0,
  travel_allow      DECIMAL(12,2) DEFAULT 0,
  special_allow     DECIMAL(12,2) DEFAULT 0,
  other_allow       DECIMAL(12,2) DEFAULT 0,
  overtime_pay      DECIMAL(12,2) DEFAULT 0,
  bonus             DECIMAL(12,2) DEFAULT 0,
  gross_salary      DECIMAL(12,2) DEFAULT 0,
  -- Deductions
  pf_employee       DECIMAL(12,2) DEFAULT 0,
  esi_employee      DECIMAL(12,2) DEFAULT 0,
  professional_tax  DECIMAL(12,2) DEFAULT 0,
  tds               DECIMAL(12,2) DEFAULT 0,
  loan_deduction    DECIMAL(12,2) DEFAULT 0,
  other_deduction   DECIMAL(12,2) DEFAULT 0,
  lop_deduction     DECIMAL(12,2) DEFAULT 0,
  total_deductions  DECIMAL(12,2) DEFAULT 0,
  net_salary        DECIMAL(12,2) DEFAULT 0,
  -- Attendance
  working_days      INT DEFAULT 26,
  days_present      INT DEFAULT 0,
  days_absent       INT DEFAULT 0,
  days_leave        INT DEFAULT 0,
  -- Status
  status            ENUM('Draft','Approved','Paid') DEFAULT 'Draft',
  paid_at           DATETIME NULL,
  created_at        TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  UNIQUE KEY uq_emp_month_year (employee_id, month, year),
  FOREIGN KEY (payroll_run_id) REFERENCES payroll_runs(id) ON DELETE CASCADE,
  FOREIGN KEY (employee_id)    REFERENCES employees(id)    ON DELETE CASCADE
);

