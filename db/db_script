USE hrms_db;

-- ── Onboarding Templates ──────────────────────────────────
-- Reusable task checklists for different roles/departments
CREATE TABLE IF NOT EXISTS onboarding_templates (
  id            INT AUTO_INCREMENT PRIMARY KEY,
  name          VARCHAR(200) NOT NULL,
  description   TEXT,
  department_id INT NULL,
  role_type     VARCHAR(100),          -- e.g. "Engineer", "Manager"
  is_default    BOOLEAN DEFAULT FALSE,
  is_active     BOOLEAN DEFAULT TRUE,
  created_by    INT NOT NULL,
  created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (department_id) REFERENCES departments(id) ON DELETE SET NULL,
  FOREIGN KEY (created_by)    REFERENCES users(id)       ON DELETE RESTRICT
);

-- ── Template Tasks ────────────────────────────────────────
CREATE TABLE IF NOT EXISTS onboarding_template_tasks (
  id           INT AUTO_INCREMENT PRIMARY KEY,
  template_id  INT NOT NULL,
  title        VARCHAR(300) NOT NULL,
  description  TEXT,
  category     ENUM('IT Setup','HR Paperwork','Training','Introduction','Compliance','Access','Other') DEFAULT 'Other',
  due_day      INT DEFAULT 1,          -- due N days after joining
  is_required  BOOLEAN DEFAULT TRUE,
  assigned_to_role VARCHAR(100),       -- 'HR', 'IT', 'Manager', 'Employee'
  sort_order   INT DEFAULT 0,
  FOREIGN KEY (template_id) REFERENCES onboarding_templates(id) ON DELETE CASCADE
);

-- ── Employee Onboarding Plans ─────────────────────────────
CREATE TABLE IF NOT EXISTS onboarding_plans (
  id            INT AUTO_INCREMENT PRIMARY KEY,
  employee_id   INT NOT NULL,
  template_id   INT NULL,
  title         VARCHAR(200) NOT NULL,
  joining_date  DATE NOT NULL,
  target_date   DATE NOT NULL,          -- expected completion
  status        ENUM('Not Started','In Progress','Completed','Overdue') DEFAULT 'Not Started',
  progress_pct  INT DEFAULT 0,
  buddy_id      INT NULL,               -- onboarding buddy (employee)
  manager_id    INT NULL,
  notes         TEXT,
  completed_at  DATETIME NULL,
  created_by    INT NOT NULL,
  created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  UNIQUE KEY uq_emp_plan (employee_id),
  FOREIGN KEY (employee_id) REFERENCES employees(id) ON DELETE CASCADE,
  FOREIGN KEY (template_id) REFERENCES onboarding_templates(id) ON DELETE SET NULL,
  FOREIGN KEY (buddy_id)    REFERENCES employees(id) ON DELETE SET NULL,
  FOREIGN KEY (manager_id)  REFERENCES employees(id) ON DELETE SET NULL,
  FOREIGN KEY (created_by)  REFERENCES users(id)     ON DELETE RESTRICT
);

-- ── Onboarding Tasks (instantiated from template or manual) ─
CREATE TABLE IF NOT EXISTS onboarding_tasks (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  plan_id         INT NOT NULL,
  title           VARCHAR(300) NOT NULL,
  description     TEXT,
  category        ENUM('IT Setup','HR Paperwork','Training','Introduction','Compliance','Access','Other') DEFAULT 'Other',
  due_date        DATE,
  status          ENUM('Pending','In Progress','Completed','Skipped') DEFAULT 'Pending',
  is_required     BOOLEAN DEFAULT TRUE,
  assigned_to_role VARCHAR(100) DEFAULT 'HR',
  assigned_to_emp INT NULL,
  completed_by    INT NULL,
  completed_at    DATETIME NULL,
  notes           TEXT,
  sort_order      INT DEFAULT 0,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (plan_id)        REFERENCES onboarding_plans(id) ON DELETE CASCADE,
  FOREIGN KEY (assigned_to_emp) REFERENCES employees(id)       ON DELETE SET NULL,
  FOREIGN KEY (completed_by)    REFERENCES users(id)           ON DELETE SET NULL
);

-- ── Onboarding Comments / Activity ────────────────────────
CREATE TABLE IF NOT EXISTS onboarding_comments (
  id         INT AUTO_INCREMENT PRIMARY KEY,
  plan_id    INT NOT NULL,
  task_id    INT NULL,
  comment    TEXT NOT NULL,
  created_by INT NOT NULL,
  created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (plan_id)    REFERENCES onboarding_plans(id) ON DELETE CASCADE,
  FOREIGN KEY (task_id)    REFERENCES onboarding_tasks(id) ON DELETE SET NULL,
  FOREIGN KEY (created_by) REFERENCES users(id)            ON DELETE RESTRICT
);

