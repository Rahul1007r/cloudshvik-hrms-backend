-- HRMS MODULE 23: Performance Management
-- ============================================================
USE hrms_db;

-- ── Review Cycles ─────────────────────────────────────────
CREATE TABLE IF NOT EXISTS review_cycles (
  id            INT AUTO_INCREMENT PRIMARY KEY,
  name          VARCHAR(200) NOT NULL,
  cycle_type    ENUM('Annual','Half-Yearly','Quarterly','Monthly','Probation') DEFAULT 'Annual',
  start_date    DATE NOT NULL,
  end_date      DATE NOT NULL,
  review_from   DATE NOT NULL,   -- period being reviewed
  review_to     DATE NOT NULL,
  status        ENUM('Draft','Active','Reviewing','Completed','Cancelled') DEFAULT 'Draft',
  description   TEXT,
  created_by    INT NOT NULL,
  created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (created_by) REFERENCES users(id) ON DELETE RESTRICT
);

-- ── Goals / KRAs ─────────────────────────────────────────
CREATE TABLE IF NOT EXISTS performance_goals (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  employee_id     INT NOT NULL,
  review_cycle_id INT NULL,
  title           VARCHAR(300) NOT NULL,
  description     TEXT,
  category        ENUM('Individual','Team','Department','Company') DEFAULT 'Individual',
  goal_type       ENUM('KPI','OKR','Project','Behavioral','Learning') DEFAULT 'KPI',
  target_value    VARCHAR(200),     -- e.g. "100 units", "95%", "Complete by Q3"
  actual_value    VARCHAR(200),
  weightage       DECIMAL(5,2) DEFAULT 0,   -- % weight in overall score
  due_date        DATE NULL,
  status          ENUM('Draft','Active','Completed','Missed','Cancelled') DEFAULT 'Active',
  progress_pct    INT DEFAULT 0,
  rating          TINYINT DEFAULT 0,  -- 1-5 rating given by manager
  comments        TEXT,
  created_by      INT NOT NULL,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (employee_id)     REFERENCES employees(id)     ON DELETE CASCADE,
  FOREIGN KEY (review_cycle_id) REFERENCES review_cycles(id) ON DELETE SET NULL,
  FOREIGN KEY (created_by)      REFERENCES users(id)         ON DELETE RESTRICT
);

-- ── Performance Reviews ───────────────────────────────────
CREATE TABLE IF NOT EXISTS performance_reviews (
  id                  INT AUTO_INCREMENT PRIMARY KEY,
  employee_id         INT NOT NULL,
  reviewer_id         INT NOT NULL,           -- manager/HR employee id
  review_cycle_id     INT NOT NULL,
  overall_rating      DECIMAL(3,1) DEFAULT 0, -- e.g. 4.2
  rating_label        VARCHAR(100),           -- "Exceeds Expectations", etc.
  -- Self assessment
  self_rating         DECIMAL(3,1) DEFAULT 0,
  self_comments       TEXT,
  self_submitted_at   DATETIME NULL,
  -- Manager review
  manager_rating      DECIMAL(3,1) DEFAULT 0,
  manager_comments    TEXT,
  manager_strengths   TEXT,
  manager_improvements TEXT,
  manager_submitted_at DATETIME NULL,
  -- HR / Final
  hr_comments         TEXT,
  hr_rating           DECIMAL(3,1) DEFAULT 0,
  final_rating        DECIMAL(3,1) DEFAULT 0,
  final_label         VARCHAR(100),
  -- Status
  status              ENUM('Pending Self','Pending Manager','Pending HR','Completed','Cancelled') DEFAULT 'Pending Self',
  acknowledgement_at  DATETIME NULL,
  created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  UNIQUE KEY uq_emp_cycle (employee_id, review_cycle_id),
  FOREIGN KEY (employee_id)     REFERENCES employees(id)     ON DELETE CASCADE,
  FOREIGN KEY (reviewer_id)     REFERENCES employees(id)     ON DELETE RESTRICT,
  FOREIGN KEY (review_cycle_id) REFERENCES review_cycles(id) ON DELETE CASCADE
);

-- ── Competency Ratings (per review) ──────────────────────
CREATE TABLE IF NOT EXISTS review_competencies (
  id          INT AUTO_INCREMENT PRIMARY KEY,
  review_id   INT NOT NULL,
  name        VARCHAR(200) NOT NULL,
  category    ENUM('Technical','Behavioral','Leadership','Communication','Other') DEFAULT 'Behavioral',
  self_rating    TINYINT DEFAULT 0,
  manager_rating TINYINT DEFAULT 0,
  comments    TEXT,
  FOREIGN KEY (review_id) REFERENCES performance_reviews(id) ON DELETE CASCADE
);

-- ── Development Plans ─────────────────────────────────────
CREATE TABLE IF NOT EXISTS development_plans (
  id            INT AUTO_INCREMENT PRIMARY KEY,
  employee_id   INT NOT NULL,
  review_id     INT NULL,
  title         VARCHAR(300) NOT NULL,
  description   TEXT,
  action_items  TEXT,   -- JSON array of action strings
  due_date      DATE NULL,
  status        ENUM('Planned','In Progress','Completed','Cancelled') DEFAULT 'Planned',
  created_by    INT NOT NULL,
  created_at    TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (employee_id) REFERENCES employees(id)            ON DELETE CASCADE,
  FOREIGN KEY (review_id)   REFERENCES performance_reviews(id)  ON DELETE SET NULL,
  FOREIGN KEY (created_by)  REFERENCES users(id)                ON DELETE RESTRICT
);

-- Indexes
ALTER TABLE performance_goals 
ADD INDEX idx_pg_emp (employee_id);

ALTER TABLE performance_reviews 
  ADD INDEX idx_pr_emp (employee_id),
  ADD INDEX idx_pr_cycle (review_cycle_id),
  ADD INDEX idx_pr_status (status);
  
