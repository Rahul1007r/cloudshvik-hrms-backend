-- HRMS MODULE 27: Notifications & Announcements
-- ============================================================
USE hrms_db;

-- ── Announcements ─────────────────────────────────────────
-- HR/Admin publishes company-wide or targeted announcements
CREATE TABLE IF NOT EXISTS announcements (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  title           VARCHAR(300) NOT NULL,
  body            TEXT NOT NULL,
  category        ENUM('General','HR','IT','Finance','Operations','Event','Policy','Emergency') DEFAULT 'General',
  priority        ENUM('Normal','Important','Urgent') DEFAULT 'Normal',
  -- Targeting
  audience        ENUM('All','Department','Role','Individual') DEFAULT 'All',
  department_id   INT NULL,
  target_role     VARCHAR(100) NULL,           -- e.g. 'Manager'
  target_emp_ids  TEXT NULL,                   -- JSON array of employee IDs
  -- Scheduling
  publish_at      DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
  expires_at      DATETIME NULL,
  -- Attachments
  attachment_path VARCHAR(500) NULL,
  attachment_name VARCHAR(255) NULL,
  -- Meta
  is_active       BOOLEAN DEFAULT TRUE,
  is_pinned       BOOLEAN DEFAULT FALSE,
  views_count     INT DEFAULT 0,
  created_by      INT NOT NULL,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (department_id) REFERENCES departments(id) ON DELETE SET NULL,
  FOREIGN KEY (created_by)    REFERENCES users(id)       ON DELETE RESTRICT
);

-- ── Announcement Read Receipts ────────────────────────────
CREATE TABLE IF NOT EXISTS announcement_reads (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  announcement_id INT NOT NULL,
  user_id         INT NOT NULL,
  read_at         TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  UNIQUE KEY uq_ann_read (announcement_id, user_id),
  FOREIGN KEY (announcement_id) REFERENCES announcements(id) ON DELETE CASCADE,
  FOREIGN KEY (user_id)         REFERENCES users(id)         ON DELETE CASCADE
);

-- ── System Notifications ──────────────────────────────────
-- Auto-generated per-user alerts from HRMS events
CREATE TABLE IF NOT EXISTS notifications (
  id          INT AUTO_INCREMENT PRIMARY KEY,
  user_id     INT NOT NULL,
  type        VARCHAR(80) NOT NULL,          -- e.g. 'leave_approved','task_assigned'
  title       VARCHAR(200) NOT NULL,
  message     TEXT,
  link        VARCHAR(500) NULL,             -- frontend route to navigate on click
  icon        VARCHAR(50)  DEFAULT 'bell',
  color       VARCHAR(10)  DEFAULT '#006bb7',
  is_read     BOOLEAN DEFAULT FALSE,
  created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- ── Email / Notification Templates ───────────────────────
CREATE TABLE IF NOT EXISTS notification_templates (
  id          INT AUTO_INCREMENT PRIMARY KEY,
  type        VARCHAR(80) NOT NULL UNIQUE,
  name        VARCHAR(200) NOT NULL,
  subject     VARCHAR(300),
  body_template TEXT NOT NULL,               -- supports {{placeholders}}
  channels    VARCHAR(100) DEFAULT 'in_app', -- 'in_app,email'
  is_active   BOOLEAN DEFAULT TRUE,
  created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ── Notification Preferences ─────────────────────────────
CREATE TABLE IF NOT EXISTS notification_preferences (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  user_id         INT NOT NULL UNIQUE,
  leave_updates   BOOLEAN DEFAULT TRUE,
  payroll_updates BOOLEAN DEFAULT TRUE,
  task_updates    BOOLEAN DEFAULT TRUE,
  hr_updates      BOOLEAN DEFAULT TRUE,
  announcements   BOOLEAN DEFAULT TRUE,
  email_digest    ENUM('None','Daily','Weekly') DEFAULT 'None',
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- Indexes
ALTER TABLE announcements 
  ADD INDEX idx_ann_active (is_active, publish_at),
  ADD INDEX idx_ann_dept (department_id);

ALTER TABLE announcement_reads   
  ADD INDEX idx_ar_user (user_id);

ALTER TABLE notifications        
  ADD INDEX idx_notif_user (user_id, is_read),
  ADD INDEX idx_notif_created (created_at);

