-- ── Seed: Sample attendance for current month ─────────────
INSERT IGNORE INTO attendance (employee_id, date, check_in, check_out, status, work_mode)
SELECT
  e.id,
  DATE_SUB(CURDATE(), INTERVAL seq.n DAY),
  TIMESTAMP(DATE_SUB(CURDATE(), INTERVAL seq.n DAY), '09:00:00') + INTERVAL FLOOR(RAND()*30) MINUTE,
  TIMESTAMP(DATE_SUB(CURDATE(), INTERVAL seq.n DAY), '18:00:00') + INTERVAL FLOOR(RAND()*60) MINUTE,
  CASE
    WHEN DAYOFWEEK(DATE_SUB(CURDATE(), INTERVAL seq.n DAY)) IN (1,7) THEN 'Weekend'
    WHEN RAND() < 0.05 THEN 'Absent'
    WHEN RAND() < 0.10 THEN 'Late'
    ELSE 'Present'
  END,
  ELT(FLOOR(1+RAND()*3), 'Office','Remote','Hybrid')
FROM employees e
CROSS JOIN (
  SELECT 1 AS n UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5
  UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9 UNION SELECT 10
  UNION SELECT 11 UNION SELECT 12 UNION SELECT 13 UNION SELECT 14 UNION SELECT 15
) seq
WHERE e.is_active = 1;

