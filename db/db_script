  employment_type ENUM('Full-Time','Part-Time','Contract','Internship') DEFAULT 'Full-Time',
  work_type       ENUM('On-site','Remote','Hybrid') DEFAULT 'On-site',
  location        VARCHAR(150),
  vacancies       INT DEFAULT 1,
  min_experience  DECIMAL(3,1) DEFAULT 0,  -- years
  max_experience  DECIMAL(3,1) DEFAULT 0,
  min_salary      DECIMAL(12,2) NULL,
  max_salary      DECIMAL(12,2) NULL,
  description     TEXT,
  requirements    TEXT,
  skills          TEXT,                    -- comma-separated
  status          ENUM('Draft','Open','On Hold','Closed','Cancelled') DEFAULT 'Draft',
  posted_date     DATE NULL,
  closing_date    DATE NULL,
  hiring_manager_id INT NULL,
  created_by      INT NOT NULL,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (department_id)     REFERENCES departments(id)   ON DELETE SET NULL,
  FOREIGN KEY (designation_id)    REFERENCES designations(id)  ON DELETE SET NULL,
  FOREIGN KEY (hiring_manager_id) REFERENCES employees(id)     ON DELETE SET NULL,
  FOREIGN KEY (created_by)        REFERENCES users(id)         ON DELETE RESTRICT
);

-- ── Candidates ────────────────────────────────────────────
CREATE TABLE IF NOT EXISTS candidates (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  job_opening_id  INT NOT NULL,
  full_name       VARCHAR(200) NOT NULL,
  email           VARCHAR(200) NOT NULL,
  phone           VARCHAR(20),
  current_company VARCHAR(200),
  current_designation VARCHAR(200),
  total_experience DECIMAL(3,1) DEFAULT 0,
  current_salary  DECIMAL(12,2) NULL,
  expected_salary DECIMAL(12,2) NULL,
  notice_period   INT DEFAULT 0,           -- days
  source          ENUM('LinkedIn','Naukri','Indeed','Referral','Walk-in','Company Website','Other') DEFAULT 'Other',
  referral_by     INT NULL,                -- employee id
  resume_path     VARCHAR(500),
  resume_original VARCHAR(255),
  cover_letter    TEXT,
  skills          TEXT,
  stage           ENUM('Applied','Screening','Interview','Technical','HR Round','Offer','Hired','Rejected','Withdrawn') DEFAULT 'Applied',
  rating          TINYINT DEFAULT 0,       -- 0-5
  notes           TEXT,
  is_active       BOOLEAN DEFAULT TRUE,
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (job_opening_id) REFERENCES job_openings(id) ON DELETE CASCADE,
  FOREIGN KEY (referral_by)    REFERENCES employees(id)    ON DELETE SET NULL
);

-- ── Interview Schedule ────────────────────────────────────
CREATE TABLE IF NOT EXISTS interviews (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  candidate_id    INT NOT NULL,
  job_opening_id  INT NOT NULL,
  interview_type  ENUM('Screening','Technical','HR Round','Final','Other') DEFAULT 'Screening',
