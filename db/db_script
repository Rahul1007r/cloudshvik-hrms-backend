-- HRMS MODULE 25: Helpdesk / Ticket System
-- ============================================================
USE hrms_db;

-- ── Ticket Categories ─────────────────────────────────────
CREATE TABLE IF NOT EXISTS ticket_categories (
  id          INT AUTO_INCREMENT PRIMARY KEY,
  name        VARCHAR(100) NOT NULL UNIQUE,
  description VARCHAR(255),
  color       VARCHAR(10) DEFAULT '#006bb7',
  icon        VARCHAR(50) DEFAULT 'help-circle',
  sla_hours   INT DEFAULT 24,      -- response SLA in hours
  is_active   BOOLEAN DEFAULT TRUE,
  created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ── Helpdesk Tickets ──────────────────────────────────────
CREATE TABLE IF NOT EXISTS helpdesk_tickets (
  id              INT AUTO_INCREMENT PRIMARY KEY,
  ticket_no       VARCHAR(20) NOT NULL UNIQUE,   -- TKT-000001
  subject         VARCHAR(300) NOT NULL,
  description     TEXT NOT NULL,
  category_id     INT NOT NULL,
  priority        ENUM('Low','Medium','High','Critical') DEFAULT 'Medium',
  status          ENUM('Open','In Progress','Waiting','Resolved','Closed','Reopened') DEFAULT 'Open',
  raised_by       INT NOT NULL,     -- employee_id
  assigned_to     INT NULL,         -- employee_id (support agent)
  department_id   INT NULL,         -- affected department
  due_date        DATETIME NULL,    -- SLA deadline
  resolved_at     DATETIME NULL,
  closed_at       DATETIME NULL,
  first_response_at DATETIME NULL,
  satisfaction_rating TINYINT NULL, -- 1-5 rating after close
  satisfaction_comment TEXT NULL,
  tags            VARCHAR(500),     -- comma-separated
  created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  updated_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
  FOREIGN KEY (category_id)   REFERENCES ticket_categories(id) ON DELETE RESTRICT,
  FOREIGN KEY (raised_by)     REFERENCES employees(id)         ON DELETE RESTRICT,
  FOREIGN KEY (assigned_to)   REFERENCES employees(id)         ON DELETE SET NULL,
  FOREIGN KEY (department_id) REFERENCES departments(id)       ON DELETE SET NULL
);

-- ── Ticket Replies / Thread ───────────────────────────────
CREATE TABLE IF NOT EXISTS ticket_replies (
  id          INT AUTO_INCREMENT PRIMARY KEY,
  ticket_id   INT NOT NULL,
  message     TEXT NOT NULL,
  reply_type  ENUM('Reply','Note','Status Change','Assignment') DEFAULT 'Reply',
  is_internal BOOLEAN DEFAULT FALSE,   -- internal note — not visible to raiser
  author_emp_id INT NOT NULL,          -- employee_id of the person replying
  created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (ticket_id)     REFERENCES helpdesk_tickets(id) ON DELETE CASCADE,
  FOREIGN KEY (author_emp_id) REFERENCES employees(id)        ON DELETE RESTRICT
);

-- ── Ticket Attachments ────────────────────────────────────
CREATE TABLE IF NOT EXISTS ticket_attachments (
  id          INT AUTO_INCREMENT PRIMARY KEY,
  ticket_id   INT NOT NULL,
  reply_id    INT NULL,
  file_name   VARCHAR(255) NOT NULL,
  file_path   VARCHAR(500) NOT NULL,
  file_size   INT DEFAULT 0,
  mime_type   VARCHAR(100),
  uploaded_by INT NOT NULL,
  created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
  FOREIGN KEY (ticket_id)   REFERENCES helpdesk_tickets(id) ON DELETE CASCADE,
  FOREIGN KEY (reply_id)    REFERENCES ticket_replies(id)   ON DELETE SET NULL,
  FOREIGN KEY (uploaded_by) REFERENCES employees(id)        ON DELETE RESTRICT
);

-- Indexes
ALTER TABLE helpdesk_tickets 
  ADD INDEX idx_ht_status (status),
  ADD INDEX idx_ht_raised (raised_by),
  ADD INDEX idx_ht_assigned (assigned_to),
  ADD INDEX idx_ht_priority (priority);

ALTER TABLE ticket_replies   
  ADD INDEX idx_tr_ticket (ticket_id);
